{
  "expo": {
    "name": "StarKid Command",
    "slug": "starkid-command",
    "scheme": "starkidcommand",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/backgrounds/starkid-app-default.png",
      "resizeMode": "cover",
      "backgroundColor": "#0b0f1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "eas": {
        "projectId": "5a63907a-ff3d-4362-af42-68c7b4e5765d"
      }
    },
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.onecirclesolutions.starkidcommand",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "starkid-mobile",
          "organization": "one-circle-solutions-llc"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ]
  }
}
